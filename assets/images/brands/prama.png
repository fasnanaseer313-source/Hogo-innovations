$('.Number').keypress(function (event) {
    var keycode = event.which;
    if (!(event.shiftKey == false && (keycode == 46 || keycode == 8 || keycode == 37 || keycode == 39 || (keycode >= 48 && keycode <= 57)))) {
        event.preventDefault();
    }
});
$('#reg_billing_phone').on("change",function(){
 let  mobile = $(this).val();
 if(mobile.length !="10"){
     $(".error").show();
     $("label[for='reg_billing_phone']").html("Please Enter Valid Mobile Number");
 }else{
     $(".error").hide(); 
      $("label[for='reg_billing_phone']").html(" ");
 } 
});











