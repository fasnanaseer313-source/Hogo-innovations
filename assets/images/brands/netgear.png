          <style>
            body {
              margin: 0;
              min-width: 375px;
              background: #000;
              font-family: Arial, sans-serif;
            }

            /* Base container + media fill */
            .video-container {
              position: relative;
              width: 100%;
              display: block;
              /* default: no forced height/ratio outside your ranges */
            }

            .video-container > img,
            .video-container > .media {
              position: absolute;
              inset: 0;
              width: 100%;
              height: 100%;
              object-fit: cover; /* use `contain` if you prefer letterboxing */
            }

            /* < 402px: min-height 416 */
            @media (max-width: 401px) {
              .video-container {
                aspect-ratio: auto; /* reset any previous ratio */
                height: auto; /* ensure min-height takes effect */
                min-height: 416px;
              }
            }

            /* 402–728: 4:3 (1.33) aspect ratio */
            @media (min-width: 402px) and (max-width: 728px) {
              .video-container {
                min-height: 0;
                height: auto;
                aspect-ratio: 4 / 3;
              }
            }

            /* 729–963: fixed height 542 */
            @media (min-width: 729px) and (max-width: 963px) {
              .video-container {
                aspect-ratio: auto; /* disable ratio in fixed-height ranges */
                min-height: 0;
                height: 542px;
              }
            }

            /* 964–1008: 16:9 aspect ratio */
            @media (min-width: 964px) and (max-width: 1008px) {
              .video-container {
                min-height: 0;
                height: auto;
                aspect-ratio: 16 / 9;
              }
            }

            /* 1009–1208: fixed height 472 */
            @media (min-width: 1009px) and (max-width: 1208px) {
              .video-container {
                aspect-ratio: auto;
                min-height: 0;
                height: 472px;
              }
            }

            /* 1209+: aspect ratio 2.56 (64:25) */
            @media (min-width: 1209px) {
              .video-container {
                min-height: 0;
                height: auto;
                aspect-ratio: 64 / 25; /* 2.56 */
              }
            }

            /* Text overlay styling */
            .overlay-text {
              position: absolute;
              top: 50%;
              left: 5%; /* Move text to left side */
              transform: translateY(-50%); /* Center vertically only */
              color: #ffffff;
              text-align: left;
              font-weight: bold !important;
              padding: 20px 30px;
              max-width: 45%; /* keeps text in a readable column */
            }

            .overlay-text h1 {
              font-size: 2.2rem !important;
              margin-bottom: 1rem !important;
              line-height: 1.3;
              font-weight: bold !important;
            }

            .overlay-text p {
              font-size: 1.1rem !important;
              margin-bottom: 1.5rem !important;
              line-height: 1.5;
            }

            .overlay-text a {
              display: inline-block;
              background-color: #ffffff;
              color: #000000;
              padding: 10px 24px;
              border-radius: 6px;
              text-decoration: none;
              font-weight: bold;
              transition: background 0.3s ease;
            }

            .overlay-text a:hover {
              background-color: #ffffff;
            }

            /* Responsive adjustment for small screens */
            @media (max-width: 768px) {
              .overlay-text {
                top: 5%;
                bottom: 10%;
                left: 5%;
                transform: none;
                max-width: 90%;
                font-size: 0.9rem;
              }
              .overlay-text h1 {
                font-size: 1.5rem;
              }
            }
          </style>

