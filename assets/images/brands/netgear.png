          <script type="text/javascript">
            $(document).ready(function () {
              $(".row.footer-base.align-items-end").hide();
              $(".cart.red-bubble-wrapper").hide();
              $(".tab-content").hide();
              $(".nav-item.dropdown.main-drop div.nav_wrapper").remove();
