          </script>
          <script type="text/javascript">
          $(document).ready(function() {
		  
		// read regional language data from json and render translated text 
		function getCountryCode() {
        var path = window.location.pathname;
        var parts = path.split("/");
        return parts[1] ? parts[1].toUpperCase() : "US";  // default
		console.log(countryCode);
		}

		// Read country from URL
		var countryCode = getCountryCode();
		// Load JSON file
    $.getJSON("/Error-404/error-msg.json", function(data) {
        console.log("JSON Loaded", data);

        // Check if country exists in JSON
        if (data[countryCode]) {
            $("#error-msg-1").text(data[countryCode].errormsg1);
			$("#error-msg-2").text(data[countryCode].errormsg2);
            $("#hometext").text(data[countryCode].hometext);
			$("#hometext").attr("href", data[countryCode].errorlink);

        } else {

            // fallback to US
            $("#error-msg-1").text(data["US"].errormsg1);
			$("#error-msg-2").text(data["US"].errormsg2);
            $("#hometext").text(data["US"].hometext);
			$("#hometext").attr("href", data["US"].errorlink);
        }

    }).fail(function(xhr, status, error) {
        console.error("JSON Load Failed:", status, error);
    });
		//*****
          
            // Re-enable default click behavior for top nav links
            $('#nav-wrapper .nav-link').off('click').on('click', function(e) {
              e.stopPropagation(); // stop dropdown JS
              window.location.href = $(this).attr('href'); // go to target
            });
          
            // Optional: prevent dropdowns from showing on hover
            $('.main-drop, .nav-item.dropdown').off('mouseenter mouseleave');
            $('.main-drop, .nav-item.dropdown').removeClass('show');
          });
          
          jQuery(function($){
            const targetMenu = $('header, nav, body'); // adjust scope if needed
          
            // Watch for class changes that include 'show-nav'
            const observer = new MutationObserver(function(mutations){
              mutations.forEach(function(mutation){
                if ($(mutation.target).hasClass('show-nav')) {
                  $(mutation.target).removeClass('show-nav');
                }
                $(mutation.addedNodes).each(function(){
                  if ($(this).hasClass('show-nav')) {
                    $(this).removeClass('show-nav');
                  }
                });
              });
            });
          
            // Observe for attribute/class changes in the menu area
            targetMenu.each(function(){
              observer.observe(this, { attributes: true, attributeFilter: ['class'], subtree: true });
            });
          });
        </script>

